<div
	class="tab-pane fade" id="miembros" role="tabpanel">
	{# FORMULARIO DE INVITACIÓN - Solo visible para el owner #}
	{% if app.user and group.owner.id == app.user.id %}
		<div class="card mb-4 border-0 bg-light shadow-sm">
			<div class="card-body">
				<h6 class="fw-bold mb-3" style="font-size: 0.85rem;">
					<i class="bi bi-envelope-plus me-2 text-primary"></i>INVITAR NUEVO MIEMBRO
				</h6>
				<form data-turbo="false" action="{{ path('app_group_invite', {'id': group.id}) }}" method="POST" class="row g-2">
					<div class="col-8 col-md-9">
						<input type="email" name="email" class="form-control form-control-sm border-0 shadow-sm" placeholder="correo@amigo.com" required>
					</div>
					<div class="col-4 col-md-3">
						<button type="submit" class="btn btn-primary btn-sm w-100 fw-bold rounded-pill">INVITAR</button>
					</div>
				</form>
			</div>
		</div>
	{% endif %}

	<div class="d-flex align-items-center gap-2 mb-3 px-1">
		<i class="bi bi-people-fill text-secondary"></i>
		<span class="fw-bold small text-uppercase tracking-wider text-secondary">
			Miembros del club —
			{{ group.members|length }}
		</span>
	</div>

	<div class="list-group list-group-flush shadow-sm rounded-4 border-0 overflow-hidden">
		{% for member in group.members %}
			<div
				class="list-group-item d-flex align-items-center justify-content-between py-3 px-4 border-bottom bg-white hover-item">

				{# PARTE IZQUIERDA: Avatar e Info #}
				<div class="d-flex align-items-center gap-3">
					<div class="position-relative">
						<i class="bi bi-person-circle fs-2 text-secondary-subtle"></i>
						{% if member.role == 'OWNER' %}
							<span class="position-absolute bottom-0 end-0 bg-warning border border-white rounded-circle p-1" style="width: 12px; height: 12px;"></span>
						{% endif %}
					</div>
					<div>
						<span class="fw-bold d-block text-dark" style="font-size: 0.95rem; line-height: 1.2;">
							{{ member.user.name|default(member.user.email) }}
						</span>
						{% if member.role == 'OWNER' %}
							<span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle rounded-pill mt-1" style="font-size: 0.7rem; padding: 0.25rem 0.6rem;">
								<i class="bi bi-star-fill me-1" style="font-size: 0.6rem;"></i>
								FUNDADOR
							</span>
						{% else %}
							<span class="badge bg-light text-secondary border rounded-pill mt-1" style="font-size: 0.7rem; padding: 0.25rem 0.6rem;">
								<i class="bi bi-person-fill me-1"></i>
								MIEMBRO
							</span>
						{% endif %}
					</div>
				</div>
				{# PARTE DERECHA: Botones de Acción #}
				<div>
					{% if app.user and member.user.id == app.user.id %}
						<div
							class="d-flex gap-2">
							{# Botón de ABANDONAR: Visible para todos (incluido el Owner) #}
							<button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-3 fw-bold border-2" data-bs-toggle="modal" data-bs-target="#abandonarGroupModal">
								<i class="bi bi-box-arrow-right me-1"></i>
								<span class="d-none d-md-inline">ABANDONAR</span>
							</button>

							{# Botón de ELIMINAR: SOLO para el Owner #}
							{% if member.role == 'OWNER' %}
								<button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold border-2" data-bs-toggle="modal" data-bs-target="#deleteGroupModal">
									<i class="bi bi-trash3 me-1"></i>
									<span class="d-none d-md-inline">ELIMINAR CLUB</span>
								</button>
							{% endif %}
						</div>
					{% endif %}
				</div>
			</div>
		{% endfor %}
	</div>
</div>
