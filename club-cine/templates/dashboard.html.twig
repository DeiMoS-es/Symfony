{# templates/dashboard.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Dashboard - Club de Cine{% endblock %}

{% block body %}
    <div class="container my-4 dashboard-container">
        
        {% if groups is empty %}
            <div class="glass-panel p-3 mb-4 d-flex align-items-center border-warning" role="alert">
                <i class="bi bi-stars me-3 fs-4 text-warning"></i>
                <div class="text-white">
                    Para empezar a compartir cine con tus amigos, primero debes
                    <strong class="text-warning">crear tu club</strong> o aceptar una invitación.
                </div>
            </div>
        {% endif %}

        <div class="row align-items-center mb-4">
            <div class="col-md-7">
                <h2 class="fw-bold mb-1 text-white">
                    <i class="bi bi-film text-primary me-2"></i>
                    {{ searchTerm ? 'Resultados para: "' ~ searchTerm ~ '"' : 'Películas Populares' }}
                </h2>
                <p class="text-white-50 small mb-0">Selecciona una joya para verla con tu club esta semana.</p>
            </div>

            <div class="col-md-5 mt-3 mt-md-0">
                <form action="{{ path('user_dashboard') }}" method="get">
                    <div class="glass-search-input">
                        <i class="bi bi-search ms-3 text-white-50"></i>
                        <input type="text" name="q" class="form-control" placeholder="Buscar película..." value="{{ searchTerm }}">
                        <button type="submit" class="btn btn-primary rounded-pill px-4 m-1">Explorar</button>
                    </div>
                </form>
            </div>
        </div>

        {# Cambiado a row-cols-2 en móvil para consistencia con el grupo #}
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3 g-md-4">
            {% for movie in movies.items %}
                <div class="col">
                    <div class="dashboard-card-glass h-100 d-flex flex-column">
                        <div class="position-relative overflow-hidden">
                            {% if movie.posterPath %}
                                <img src="https://image.tmdb.org/t/p/w500{{ movie.posterPath }}" 
                                     class="card-img-top d-block w-100" 
                                     alt="{{ movie.title }}" 
                                     style="aspect-ratio: 2/3; object-fit: cover;">
                            {% else %}
                                <div class="bg-dark d-flex align-items-center justify-content-center" style="aspect-ratio: 2/3;">
                                    <i class="bi bi-camera-video text-secondary fs-1"></i>
                                </div>
                            {% endif %}

                            <div class="position-absolute top-0 end-0 m-2">
                                <span class="badge glass-badge">
                                    {{ movie.releaseDate ? movie.releaseDate|date('Y') : 'TBA' }}
                                </span>
                            </div>
                        </div>

                        <div class="p-3 d-flex flex-column flex-grow-1">
                            <h6 class="text-white fw-bold mb-2 text-truncate" title="{{ movie.title }}">
                                {{ movie.title }}
                            </h6>

                            <div class="d-flex align-items-center text-white-50 mb-3" style="font-size: 0.75rem;">
                                <i class="bi bi-calendar-event me-2"></i>
                                <span>{{ movie.releaseDate ? movie.releaseDate|date('d/m/Y') : 'Sin fecha' }}</span>
                            </div>

                            {% if groups is not empty %}
                                {% set firstGroup = groups|first %}
                                <div class="mt-auto">
                                    <a href="{{ path('app_group_recommend_movie', { 'id': firstGroup.id, 'tmdbId': movie.tmdbId }) }}" 
                                       class="btn btn-outline-light btn-sm w-100 rounded-pill py-2 glass-btn">
                                        <i class="bi bi-megaphone me-1"></i>
                                        Recomendar
                                    </a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <i class="bi bi-search fs-1 text-white-50"></i>
                    <p class="text-white-50 mt-2">No hemos encontrado películas disponibles.</p>
                </div>
            {% endfor %}
        </div>
    </div>

    {# Paginación estilizada #}
    {% if totalPages > 1 %}
        <nav class="mt-5 pb-5">
            <ul class="pagination pagination-sm justify-content-center gap-2">
                <li class="page-item {{ currentPage == 1 ? 'disabled' : '' }}">
                    <a class="page-link glass-panel" href="{{ path('user_dashboard', { page: currentPage - 1, q: searchTerm }) }}">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                <li class="glass-panel px-4 d-flex align-items-center rounded-pill">
                    <span class="text-white small">Página <strong>{{ currentPage }}</strong> de {{ totalPages }}</span>
                </li>
                <li class="page-item {{ currentPage == totalPages ? 'disabled' : '' }}">
                    <a class="page-link glass-panel" href="{{ path('user_dashboard', { page: currentPage + 1, q: searchTerm }) }}">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    {% endif %}

{% endblock %}